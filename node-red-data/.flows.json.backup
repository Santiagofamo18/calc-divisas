    {
        "id": "ea5a5d2f5f4d91f6",
        "type": "function",
        "z": "hist_tab",
        "name": "Sync",
        "func": "const fecha = msg.fecha;\nlet source = '';\n\nif (msg.topic.startsWith('frankfurter')) source = 'frankfurter';\nelse if (msg.topic.startsWith('fawaz')) source = 'fawaz';\nelse if (msg.topic.startsWith('awesome')) source = 'awesome';\n\nconst bufferKey = 'buffer_' + msg._origMsgId;\nlet buffer = flow.get(bufferKey) || { _ts: Date.now() };\n\nbuffer[source] = msg.payload;\nbuffer._fecha = buffer._fecha || fecha;\nflow.set(bufferKey, buffer);\n\nconst apisPresentes = ['frankfurter', 'fawaz', 'awesome'].filter(k => buffer[k]);\nconst apisFaltantes = ['frankfurter', 'fawaz', 'awesome'].filter(k => !buffer[k]);\nconst timedOut = (Date.now() - buffer._ts) > 15000; // 15 s\n\nif (apisPresentes.length < 3 && !timedOut) {\n    return null; // Aún esperando, y no han pasado 15 s\n}\n\n// Llegamos aquí: tenemos las 3 APIs, o ha vencido el timeout\nif (apisFaltantes.length > 0) {\n    node.warn('⚠️ Timeout — APIs ausentes para ' + buffer._fecha + ': ' + apisFaltantes.join(', '));\n}\n\nflow.set(bufferKey, null);\n\nmsg.fecha = buffer._fecha;\nmsg.payload = {\n    frankfurter: buffer.frankfurter || {},\n    fawaz: buffer.fawaz || {},\n    awesome: buffer.awesome || {}\n};\nreturn msg;",
        "outputs": 1,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 950,
        "y": 360,
        "wires": [
            [
                "hist_calc"
            ]
        ]
    },
    {
        "id": "9e95b5e4f151a902",
        "type": "http request",
        "z": "hist_tab",
        "name": "AwesomeAPI histórico",
        "method": "GET",
        "ret": "obj",
        "paytoqs": "ignore",
        "url": "https://economia.awesomeapi.com.br/json/last/EUR-USD,EUR-GBP,EUR-JPY",
        "tls": "",
        "persist": false,
        "proxy": "",
        "insecureHTTPParser": false,
        "authType": "",
        "senderr": false,
        "headers": [],
        "x": 540,
