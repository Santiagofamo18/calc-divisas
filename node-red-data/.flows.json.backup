        "type": "influxdb batch",
        "z": "55670685a4ad1746",
        "influxdb": "b1d2f3e4.5a6b7c8",
        "precision": "",
        "retentionPolicy": "",
        "name": "Write to Influx",
        "database": "",
        "retentionPolicyV18Flux": "",
        "org": "${INFLUXDB_ORG}",
        "bucket": "${INFLUXDB_BUCKET}",
        "x": 1740,
        "y": 280,
