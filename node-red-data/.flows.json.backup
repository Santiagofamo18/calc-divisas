        ]
    },
    {
        "id": "70f98be10a88f440",
        "type": "function",
        "z": "hist_tab",
        "name": "Norm AwesopeAPI",
        "func": "const fecha = flow.get('fecha_actual');\n\nmsg.topic = 'awesome_' + fecha;\nmsg.fecha = fecha;\n\nconst rates = {};\n\nif (typeof msg.payload === 'object' && msg.payload !== null) {\n    for (const pair in msg.payload) {\n        const item = msg.payload[pair];\n\n        if (!item) continue;\n\n        const code = item.codein;\n        const bid = parseFloat(item.bid);\n\n        if (code && !isNaN(bid)) {\n            rates[code.toUpperCase()] = bid;\n        }\n    }\n}\n\nnode.warn(\n    `AwesomeAPI (${fecha}) → ${Object.keys(rates).length} monedas: ${Object.keys(rates).join(', ')}`\n);\n\nmsg.payload = {\n    rates,\n    date: fecha\n};\n\nreturn msg;",
        "outputs": 1,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 770,
        "y": 520,
        "wires": [
            [
                "ea5a5d2f5f4d91f6"
            ]
        ]
    }
