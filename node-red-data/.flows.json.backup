                "hist_norm_fawaz"
            ]
        ]
    },
    {
        "id": "hist_norm_frankfurter",
        "type": "function",
        "z": "hist_tab",
        "name": "Norm Frankfurter",
        "func": "const fecha = flow.get('fecha_actual');\n\nmsg.topic = 'frankfurter_' + fecha;\nmsg.fecha = fecha;\n\nmsg.payload = {\n    rates: msg.payload.rates || {},\n    date: fecha\n};\n\nreturn msg;",
        "outputs": 1,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 770,
        "y": 300,
        "wires": [
