        "wires": []
    },
    {
        "id": "76c7fd9951bc59d2",
        "type": "function",
        "z": "55670685a4ad1746",
        "name": "Query",
        "func": "const d = msg.payload;\n\nmsg.query = `INSERT INTO monedas (codigo) VALUES ($1) ON CONFLICT (codigo) DO NOTHING`;\nmsg.params = [d.codigo];\nmsg.payload = {};\nmsg._divisa = d;\n\nreturn msg;",
        "outputs": 1,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 1610,
        "y": 220,
        "wires": [
            []
        ]
    },
