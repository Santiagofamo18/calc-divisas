    {
        "id": "bed198732c260698",
        "type": "function",
        "z": "55670685a4ad1746",
        "name": "Calc",
        "func": "const apis = msg.payload;\nconst mapaDivisas = {};\nconst fechas = [];\n\nfor (const apiTag in apis) {\n    const apiData = apis[apiTag];\n    if (!apiData || typeof apiData !== 'object') continue;\n    if (apiData.date) fechas.push(apiData.date);\n\n    const tasas = apiData.rates || apiData;\n    for (const [codigo, valor] of Object.entries(tasas)) {\n        const codigoNorm = codigo.toUpperCase();\n        if (!mapaDivisas[codigoNorm]) {\n            mapaDivisas[codigoNorm] = { suma: 0, conteo: 0 };\n        }\n        mapaDivisas[codigoNorm].suma += valor;\n        mapaDivisas[codigoNorm].conteo += 1;\n    }\n}\n\nconst todasIguales = fechas.length === 4 && fechas.every(f => f === fechas[0]);\n\nif (!todasIguales) {\n    node.warn(`⏳ APIs en fechas distintas: ${fechas.join(', ')} — bloqueando`);\n    return null;\n}\n\nconst fecha = fechas[0];\nconst resultados = Object.keys(mapaDivisas).map(codigo => ({\n    codigo,\n    media: mapaDivisas[codigo].suma / mapaDivisas[codigo].conteo,\n    fuentes: mapaDivisas[codigo].conteo,\n    fecha\n}));\n\nmsg.payload = resultados;\nreturn msg;",
        "outputs": 1,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 1270,
        "y": 220,
        "wires": [
            [
                "43bf0f093b23f31d"
            ]
        ]
    },
