    {
        "id": "185abda84b36cc6f",
        "type": "join",
        "z": "55670685a4ad1746",
        "name": "",
        "mode": "custom",
        "build": "object",
        "property": "payload",
        "propertyType": "msg",
        "key": "topic",
        "joiner": "\\n",
        "joinerType": "str",
        "accumulate": true,
        "timeout": "5",
        "count": "3",
        "x": 1100,
        "y": 220,
        "wires": [
            [
                "c937544a1876b5a3",
                "bed198732c260698"
            ]
        ]
    },
    {
        "id": "bed198732c260698",
        "type": "function",
        "z": "55670685a4ad1746",
        "name": "Calc",
        "func": "const apis = msg.payload;\nconst mapaDivisas = {};\nlet apiDate = null;\n\nfor (const apiTag in apis) {\n    const apiData = apis[apiTag];\n    if (!apiData || typeof apiData !== 'object') continue;\n    const tasas = apiData.rates || apiData;\n    if (!apiDate && apiData.date) {\n        apiDate = apiData.date;\n    }\n\n    for (const [codigo, valor] of Object.entries(tasas)) {\n        if (!mapaDivisas[codigo]) {\n            mapaDivisas[codigo] = { suma: 0, conteo: 0 };\n        }\n        mapaDivisas[codigo].suma += valor;\n        mapaDivisas[codigo].conteo += 1;\n    }\n}\n\nconst fecha = apiDate || new Date().toISOString().split('T')[0];\nconst resultados = Object.keys(mapaDivisas).map(codigo => ({\n    codigo: codigo,\n    media: mapaDivisas[codigo].suma / mapaDivisas[codigo].conteo,\n    fuentes: mapaDivisas[codigo].conteo,\n    fecha\n}));\n\nmsg.payload = resultados;\nreturn msg;",
        "outputs": 1,
        "x": 1270,
        "y": 220,
        "wires": [
            [
                "dd1b87b9b3bb941e",
                "c3e89cc82270a290"
            ]
        ]
    },
    {
        "id": "c937544a1876b5a3",
        "type": "debug",
        "z": "55670685a4ad1746",
        "name": "debug 1",
        "active": true,
        "tosidebar": true,
        "console": false,
        "tostatus": false,
        "complete": "false",
