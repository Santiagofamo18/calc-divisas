    {
        "id": "fcd635b7bc8b6c78",
        "type": "function",
        "z": "55670685a4ad1746",
        "name": "Estandarización",
        "func": "msg.topic = \"awesome\";\nconst rates = {};\n\nfor (const pair in msg.payload) {\n    const code = pair.substring(3); \n    rates[code] = parseFloat(msg.payload[pair].bid);\n}\n\nmsg.payload = {\n    rates: rates,\n    date: new Date().toISOString().split(\"T\")[0]\n};\nreturn msg;",
        "outputs": 1,
        "noerr": 0,
