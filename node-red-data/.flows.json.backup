    {
        "id": "c3e89cc82270a290",
        "type": "function",
        "z": "55670685a4ad1746",
        "name": "Build Influx points",
        "func": "const records = msg.payload || [];\n\nmsg.payload = records.map(item => {\n    const numApis = Math.round(Number(item.fuentes ?? item.num_apis ?? 0));\n    return {\n        measurement: \"divisas\",\n        tags: { Codigo_moneda: (item.codigo || item.Codigo_moneda || \"\").toUpperCase() },\n        fields: {\n            Valor_media: Number(item.media ?? item.valor_media ?? 0),\n            Num_apis: { value: numApis, type: \"integer\" }\n        },\n        timestamp: new Date()\n    };\n});\n\nreturn msg;",
        "outputs": 1,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 1750,
        "y": 220,
        "wires": [
            [
                "9c7d0f6a8b5c3d21"
            ]
        ]
    },
    {
        "id": "43bf0f093b23f31d",
        "type": "function",
        "z": "55670685a4ad1746",
        "name": "date_today",
        "func": "const hoy = new Date().toLocaleDateString('sv-SE');\nconst fechaApi = msg.payload[0]?.fecha;\n\nif (fechaApi === hoy) {\n    node.warn(`APIs actualizadas al ${hoy} — subiendo datos`);\n    return [msg, null]; \n} else {\n    node.warn(`APIs aún en ${fechaApi}, reintentando en 30 min...`);\n    return [null, msg]; \n}",
        "outputs": 2,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
