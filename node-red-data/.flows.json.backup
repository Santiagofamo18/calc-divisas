        "z": "hist_tab",
        "name": "Fawaz histórico",
        "method": "GET",
        "ret": "obj",
        "url": "https://cdn.jsdelivr.net/npm/@fawazahmed0/currency-api@{{{payload}}}/v1/currencies/eur.json",
        "x": 530,
