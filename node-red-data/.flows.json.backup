    {
        "id": "841ce82da8934bbc",
        "type": "function",
        "z": "55670685a4ad1746",
        "name": "Estandarización",
        "func": "msg.topic = \"frankfurter\";\nmsg.payload = {\n    rates: msg.payload.rates || {},\n    date: msg.payload.date || new Date().toISOString().split(\"T\")[0]\n};\nreturn msg;",
