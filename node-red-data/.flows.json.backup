    },
    {
        "id": "c3e89cc82270a290",
        "type": "function",
        "z": "55670685a4ad1746",
        "name": "Build Influx points",
        "func": "const records = msg.payload || [];\n\nmsg.payload = records.map(item => {\n    const fecha = item.fecha || item.Fecha || new Date().toISOString().split(\"T\")[0];\n    const numApis = Number(item.fuentes ?? item.num_apis ?? 0);\n    return {\n        measurement: \"divisas\",\n        tags: { Codigo_moneda: (item.codigo || item.Codigo_moneda || \"\").toUpperCase() },\n        fields: {\n            Valor_media: Number(item.media ?? item.valor_media ?? 0),\n            Num_apis: numApis\n        },\n        timestamp: new Date(fecha)\n    };\n});\n\nreturn msg;",
        "outputs": 1,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 1490,
        "y": 280,
        "wires": [
            [
                "9c7d0f6a8b5c3d21"
            ]
        ]
    }
