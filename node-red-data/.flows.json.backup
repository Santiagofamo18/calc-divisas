    {
        "id": "hist_inject",
        "type": "inject",
        "z": "hist_tab",
        "name": "Fecha inicio",
        "props": [
            {
                "p": "payload"
            }
        ],
        "repeat": "",
        "crontab": "",
        "once": false,
        "onceDelay": "",
        "topic": "",
        "payload": "2026-05-01",
        "payloadType": "str",
        "x": 160,
