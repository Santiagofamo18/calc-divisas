            [
                "hist_init"
            ]
        ]
    },
    {
        "id": "hist_init",
        "type": "function",
        "z": "hist_tab",
        "name": "Generar lista de fechas",
        "func": "const fechaInicio = msg.payload;\nconst hoy = new Date().toLocaleDateString('sv-SE');\nconst fechas = [];\nlet cursor = new Date(fechaInicio);\nconst fin = new Date(hoy);\nwhile (cursor <= fin) {\n    fechas.push(cursor.toLocaleDateString('sv-SE'));\n    cursor.setDate(cursor.getDate() + 1);\n}\nflow.set('fechas_pendientes', fechas);\nflow.set('fecha_idx', 0);\nflow.set('total_fechas', fechas.length);\nnode.warn('Procesando ' + fechas.length + ' días desde ' + fechaInicio + ' hasta ' + hoy);\nmsg.payload = fechas[0];\nreturn msg;",
        "outputs": 1,
        "x": 360,
        "y": 200,
        "wires": [
            [
                "hist_link_out"
            ]
        ]
    },
    {
        "id": "hist_link_out",
        "type": "link out",
        "z": "hist_tab",
        "name": "link out fecha",
        "mode": "link",
        "links": [
            "hist_link_in"
        ],
        "x": 555,
        "y": 200,
        "wires": []
    },
    {
        "id": "hist_link_in",
        "type": "link in",
        "z": "hist_tab",
        "name": "link in fecha",
        "links": [
            "hist_link_out",
            "hist_next_link_out"
        ],
        "x": 165,
        "y": 360,
        "wires": [
            [
                "hist_build_urls"
            ]
        ]
    },
    {
        "id": "hist_build_urls",
        "type": "function",
        "z": "hist_tab",
        "name": "Build URLs",
        "func": "const fecha = msg.payload;\nflow.set('fecha_actual', fecha);\n\nmsg.fecha = fecha;\n// Formato YYYYMMDD para AwesomeAPI\nmsg.fechaAwesome = fecha.replace(/-/g, '');\nmsg._origMsgId = msg._msgid;\n\nreturn msg;",
        "outputs": 1,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 320,
        "y": 360,
        "wires": [
