            ]
        ]
    },
    {
        "id": "hist_norm_fawaz",
        "type": "function",
        "z": "hist_tab",
        "name": "Norm Fawaz",
        "func": "const fecha = flow.get('fecha_actual');\n\nmsg.topic = 'fawaz_' + fecha;\nmsg.fecha = fecha;\n\nmsg.payload = {\n    rates: msg.payload.eur || {},\n    date: fecha\n};\n\nreturn msg;",
        "outputs": 1,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 760,
        "y": 420,
        "wires": [
            [
                "ea5a5d2f5f4d91f6"
            ]
        ]
    },
    {
        "id": "hist_calc",
        "type": "function",
        "z": "hist_tab",
        "name": "Calc histórico",
        "func": "const apis = msg.payload;\nconst mapaDivisas = {};\nlet fecha = null;\n\nfor (const apiTag in apis) {\n    const apiData = apis[apiTag];\n    if (!apiData || typeof apiData !== 'object') continue;\n    if (!fecha && apiData.date) fecha = apiData.date;\n    const tasas = apiData.rates || apiData;\n    for (const [codigo, valor] of Object.entries(tasas)) {\n        const codigoNorm = codigo.toUpperCase();\n        if (typeof valor !== 'number') continue;\n        if (!mapaDivisas[codigoNorm]) {\n            mapaDivisas[codigoNorm] = { suma: 0, conteo: 0 };\n        }\n        mapaDivisas[codigoNorm].suma += valor;\n        mapaDivisas[codigoNorm].conteo += 1;\n    }\n}\n\nif (!fecha) {\n    node.warn('Sin fecha, saltando...');\n    return null;\n}\n\nconst resultados = Object.keys(mapaDivisas).map(codigo => ({\n    codigo: codigo,\n    media: mapaDivisas[codigo].suma / mapaDivisas[codigo].conteo,\n    fuentes: mapaDivisas[codigo].conteo, // Mantenemos fuentes\n    num_apis: mapaDivisas[codigo].conteo, // Añadimos alias por seguridad\n    fecha: fecha\n}));\n\nconst idx = flow.get('fecha_idx') || 0;\nconst total = flow.get('total_fechas') || 0;\nnode.warn('[' + (idx + 1) + '/' + total + ']  ' + fecha + ' — ' + resultados.length + ' monedas');\n\nmsg.payload = resultados;\nmsg.fecha = fecha;\n\n// Al final de Calc histórico, antes de return msg:\nconst resumen = resultados.reduce((acc, r) => {\n    acc[r.fuentes] = (acc[r.fuentes] || 0) + 1;\n    return acc;\n}, {});\nnode.warn('[' + (idx+1) + '/' + total + '] ' + fecha \n    + ' — ' + resultados.length + ' monedas | fuentes: ' + JSON.stringify(resumen));\n    \nreturn msg;",
        "outputs": 1,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 1140,
        "y": 360,
        "wires": [
            [
                "hist_build_influx"
            ]
        ]
    },
    {
        "id": "hist_build_influx",
        "type": "function",
        "z": "hist_tab",
        "name": "Build Influx points",
        "func": "const records = msg.payload || [];\nconst fecha = msg.fecha;\n\nmsg.payload = records.map(item => {\n    // 1. Obtenemos el valor numérico\n    const valorFuentes = item.fuentes !== undefined ? item.fuentes : (item.num_apis ?? 0);\n    const numApis = parseInt(valorFuentes, 10) || 0;\n\n    return {\n        measurement: 'divisas',\n        tags: {\n            Codigo_moneda: item.codigo.toUpperCase()\n        },\n        fields: {\n            Valor_media: Number(item.media.toFixed(6)),\n            Num_apis: numApis // <-- Enviamos el número directamente\n        },\n        timestamp: new Date(fecha + 'T12:00:00Z')\n    };\n});\nreturn msg;",
        "outputs": 1,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 1340,
        "y": 360,
        "wires": [
            [
                "hist_write_influx",
                "hist_next_day"
            ]
        ]
    },
