    },
    {
        "id": "hist_next_day",
        "type": "function",
        "z": "hist_tab",
        "name": "Siguiente día",
        "func": "const fechas = flow.get('fechas_pendientes') || [];\nlet idx = flow.get('fecha_idx') || 0;\nidx += 1;\n\nif (idx >= fechas.length) {\n    node.warn('🎉 Histórico completado — ' + fechas.length + ' días procesados');\n    return null;\n}\n\nflow.set('fecha_idx', idx);\nmsg.payload = fechas[idx];\nreturn msg;",
        "outputs": 1,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
